# Copy this file to .streamlit/secrets.toml and fill in your values.
# On Streamlit Community Cloud, add these via the app's Secrets settings (never commit secrets.toml).

# Gmail credentials for sending municipal dispatch emails.
# Use a Gmail App Password (not your account password).
# See: https://support.google.com/accounts/answer/185833
SMTP_EMAIL = "your-email@gmail.com"
SMTP_PASSWORD = "your-app-password"
